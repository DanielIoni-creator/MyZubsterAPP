# =============================================
# MYZUBSTER - ENVIRONMENT VARIABLES
# =============================================

# ---- Server ----
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ---- Database (MongoDB Atlas) ----
MONGODB_URI=mongodb://rossieugenio17_db_user:password123@ac-e7oay8r-shard-00-00.dajuchx.mongodb.net:27017,ac-e7oay8r-shard-00-01.dajuchx.mongodb.net:27017,ac-e7oay8r-shard-00-02.dajuchx.mongodb.net:27017/myzubster?ssl=true&replicaSet=atlas-fl7a5n-shard-0&authSource=admin&appName=Cluster0&compressors=zlib

# ---- Redis (opzionale) ----
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# =============================================
# BLOCKCHAIN / WEB3
# =============================================

# ---- Provider ----
WEB3_PROVIDER=http://localhost:8545

# ---- Contract Addresses ----
FEE_CONTRACT_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512
GOVERNANCE_TOKEN_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# ---- Private Key (SOLO per testnet/mainnet) ----
# PRIVATE_KEY=0x1234567890123456789012345678901234567890123456789012345678901234

# =============================================
# MONERO
# =============================================

MONERO_RPC_URL=http://localhost:18082
MONERO_WALLET_PASSWORD=your_secure_password
MONERO_WALLET_ADDRESS=your_monero_address
MONERO_NETWORK=stagenet

# =============================================
# FEE CONFIGURATION (iniziale)
# =============================================

FEE_BASE=100
FEE_VARIABLE=200
FEE_DISCOUNT_THRESHOLD=10000
FEE_DISCOUNT_RATE=150

# =============================================
# TREASURY WALLETS (per distribuzione fee)
# =============================================

TREASURY_WALLET=0xTreasuryAddressHere
COMMUNITY_WALLET=0xCommunityAddressHere
STAKING_WALLET=0xStakingAddressHere

# =============================================
# SECURITY
# =============================================

JWT_SECRET=myzubster_super_secret_key_change_me
JWT_EXPIRES_IN=7d
BCRYPT_SALT=10

# =============================================
# FEATURES FLAGS
# =============================================

ENABLE_FEE_MONITORING=true
ENABLE_GOVERNANCE=true
ENABLE_STAKING=true
ENABLE_AUTO_DISTRIBUTION=true

# =============================================
# CORS
# =============================================

CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# =============================================
# LOGGING
# =============================================

LOG_LEVEL=info
LOG_FILE=logs/app.log

# =============================================
# MOCK PAYMENT
# =============================================

MOCK_PAYMENT_DELAY=3000