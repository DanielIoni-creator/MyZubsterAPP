# =============================================
# MYZUBSTER - ENVIRONMENT VARIABLES (ESEMPIO)
# =============================================
# 📌 Copia questo file come .env e compila con i tuoi dati
# ⚠️ NON caricare mai il file .env su GitHub!

# ---- Server ----
PORT=3000

# ---- Database (MongoDB) ----
MONGODB_URI=mongodb://localhost:27017/myzubster
MONGODB_DB=myzubster

# ---- Security ----
JWT_SECRET=your_jwt_secret_key_here_change_me

# =============================================
# MONERO PAYMENT GATEWAY
# =============================================

# 💡 Preferisci un'istanza self-hosted di MoneroPay quando disponibile.
# Il backend non espone mai i segreti del wallet ai client Android.
MONEROPAY_URL=http://127.0.0.1:5000

# 💡 Wallet RPC fallback usato quando MONEROPAY_URL non è impostato.
# Dovrebbe essere un servizio wallet view-only/merchant.
MONERO_WALLET_RPC_URL=http://127.0.0.1:18083/json_rpc

# 💡 URL del nodo Monero (monerod) per health check e contesto block height.
# Può essere il tuo monerod o un nodo pubblico.
MONERO_NODE_URL=http://127.0.0.1:18081/json_rpc

# Credenziali RPC (se richieste)
MONERO_RPC_USERNAME=
MONERO_RPC_PASSWORD=

# =============================================
# MERCHANT CONFIGURATION
# =============================================

# Account index del wallet (0 = account principale)
MONERO_ACCOUNT_INDEX=0

# Numero di conferme richieste (0 = non attendere)
MONERO_CONFIRMATIONS_DEFAULT=0

# Percorso del file per salvare i pagamenti (JSON)
MONERO_PAYMENT_STORE=./data/payments.json

# Webhook per notifiche di pagamento
PAYMENT_WEBHOOK_SECRET=your_webhook_secret_here
PAYMENT_STATUS_CALLBACK_URL=http://your-domain.com/api/payments/callback

# Simulazione pagamento (ms) - solo per test
MONERO_PAYMENT_SIMULATION_MS=10000

# Commissione piattaforma (es. 0.02 = 2%)
PAYMENT_PLATFORM_FEE_RATE=0.02

# Wallet dove inviare le commissioni della piattaforma
PLATFORM_FEE_WALLET_ADDRESS=your_platform_fee_wallet_address_here

# =============================================
# FIREBASE CLOUD MESSAGING (opzionale)
# =============================================

# Percorso del file di servizio Firebase Admin (JSON)
FIREBASE_SERVICE_ACCOUNT_PATH=./path/to/firebase-service-account.json

# Oppure, contenuto JSON diretto (se non si usa un file)
FIREBASE_SERVICE_ACCOUNT_JSON=

# =============================================
# FEATURE FLAGS (opzionale)
# =============================================

# Abilita il monitoraggio delle fee
ENABLE_FEE_MONITORING=true

# Abilita la governance (se utilizzata)
ENABLE_GOVERNANCE=false

# Abilita lo staking (se utilizzato)
ENABLE_STAKING=false

# Abilita la distribuzione automatica delle fee
ENABLE_AUTO_DISTRIBUTION=false

# =============================================
# LOGGING
# =============================================

LOG_LEVEL=info
LOG_FILE=logs/app.log